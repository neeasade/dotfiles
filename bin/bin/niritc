#!/usr/bin/env bash

socket="/tmp/niritd.sock"

# todo: if niritd not running, start it + wait a sec

args="$1"
shift
for arg in "$@"; do
    args="${args}^${arg}"
done

echo "sending $args"
socat - UNIX-CONNECT:"${socket}" <<< "$args"

# idea: if we are sending "quit"
# emit an event so that niritd can exit right away
