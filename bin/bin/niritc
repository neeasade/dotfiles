#!/usr/bin/env bash

socket="/tmp/niritd.sock"
# socket="/tmp/socket.sock"

# todo: if niritd not running, start it + wait a sec

args="$1"
shift
for arg in "$@"; do
    args="${args}^${arg}"
done

wrap() {
    read -r first_line;
    if [[ $first_line == EXITCODE* ]]; then
	eval "$first_line"
    else
	echo "$first_line"
    fi

    cat -
    exit ${EXITCODE:-0}
}

socat - UNIX-CONNECT:"${socket}" <<< "$args" | wrap
