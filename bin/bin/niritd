(defn action [command & args]
  ;; debug
  ;; (prn action command)
  (apply lib/shh "niri" "msg" "action" (name command) (map str args))
  ;; (string/join " " (concat ["niri" "msg" "action" (name command)] (map str args)))
  )

;; niri msg *
;; outputs windows keyboard-layouts focused-window pick-color output version overview-state
;; workspaces layers focused-output pick-window action event-stream request-error help
(defn msg [kind]
  (json/parse-string (lib/shh (str "niri msg --json " (name kind))) true))

(def SOCKET "/tmp/niritd.sock")

;; niri-state-loop
(def niri-state (atom {:output (msg :focused-output)}))
(def niri-state-channel nil)

(defn edge?
  ([dir] (edge? (:focused @niri-state) dir))
  ([win dir]
   (if (-> @niri-state :focused :is_floating)
     false
     (let [win-column (-> win :layout :pos_in_scrolling_layout first)
           columns (->> (:windows @niri-state)
                        (vals)
                        (filter #(= (:workspace_id %) (:workspace_id win)))
                        (map #(-> % :layout :pos_in_scrolling_layout first))
                        (distinct)
                        (sort))]
       (condp = dir
         "left" (= (first columns) win-column)
         "right" (= (last columns) win-column)
         (println "edge? what"))))))

(defn siblings
  ;; "siblings" are windows in the same column as you
  ([] (siblings (:focused @niri-state)))
  ([win]
   (let [win-column (-> win :layout :pos_in_scrolling_layout first)
         siblings (->> (:windows @niri-state)
                       (vals)
                       (remove #(= (:id %) (:id win)))
                       (filter #(= (:workspace_id %) (:workspace_id win)))
                       (filter #(= (-> % :layout :pos_in_scrolling_layout first) win-column)))]
     (if (empty? siblings) nil
         siblings))))

(defn swap-or-move [dir]
  (if (edge? (:focused @niri-state) dir)
    (action (str "consume-or-expel-window-" dir))
    (action (str "swap-window-" dir) )))

;; this really depends on if you're focused right or left
(defn rotate []
  (action :move-column-left)
  (action :focus-column-right))

(defn rotate-reverse []
  (action :move-column-right)
  (action :focus-column-left))


(defn tabbed? [window-id]
  ;; todo: have this use siblings
  ;; Check if a window is in a tabbed layout by comparing window sizes in the same column
  (let [windows (vals (:windows @niri-state))
        target-window (get (:windows @niri-state) window-id)]
    (when target-window
      (let [target-pos (first (get-in target-window [:layout :pos_in_scrolling_layout]))
            target-workspace (:workspace_id target-window)
            mon-height (-> @niri-state :output :logical :height)
            same-column-windows (filter #(and (= target-workspace (:workspace_id %))
                                              (= target-pos (first (get-in % [:layout :pos_in_scrolling_layout]))))
                                        windows)
            window-sizes (map #(get-in % [:layout :window_size]) same-column-windows)]
        ;; Windows are tabbed if there's more than one window and they all have the same size
        (and (> (count same-column-windows) 1)
             (apply = window-sizes)
             ;; broken:
             ;; false
             (> (second (first window-sizes))
                (* 0.7 mon-height)))))))

(defn go-dir [dir]
  ;; todo: go-dir should center if you can't go dir
  (let [win (:focused @niri-state)
        term? (#{"Alacritty" "foot" "kitty"} (:app_id win))
        elisp (format "(when-let (win (and (frame-focus-state) (window-in-direction '%s))) (select-window win))" dir)
        niri-move (condp = dir
                    ;; "left" (fn [] (action "focus-window-up-or-column-left"))
                    ;; "right" (fn [] (action "focus-window-down-or-column-right"))

                    "left" (fn []
                             (if (edge? "left")
                               (action :center-window)
                               (action :focus-column-left)))
                    "right" (fn []
                              (if (edge? "right")
                                (action :center-window)
                                (action :focus-column-right)))

                    "up" (fn [] (if (tabbed? (:id win))
                                  (action :focus-workspace-up)
                                  (action :focus-window-or-workspace-up)))
                    "down" (fn [] (if (tabbed? (:id win))
                                    (action :focus-workspace-down)
                                    (action :focus-window-or-workspace-down))))]
    (if term?
      (when-not
          (= 0 (:exit (shell/sh "elisp" "-t" "1" elisp)))
        (niri-move))
      (niri-move))))

(comment
  (edge? "left")

  )

(defn find-class
  ([class] (find-class class false false))
  ([class reverse? global?]
   ;; find or rotate windows by class/"App id"
   (let [data (vals (:windows @niri-state))
         active-window (:focused @niri-state)
         last-active-window (:focused-last @niri-state)

         active-wid (:id active-window)
         data (sort-by #(-> % :layouts :pos_in_scrolling_layout first) data)
         wids (keep (fn [w]
                      (when (and
                             ;; comping for a bug where a nil window id is present
                             ;; todo: track down state bug
                             (not (nil? (:id w)))
                             (re-matches (re-pattern class) (last (string/split (:app_id w) #"\.")))
                             ;; scope to current workspace
                             (or global? (= (:workspace_id active-window) (:workspace_id w))))
                        (:id w)))
                    data)

         ;; (:focused @niri-state)

         wids (concat wids [(first wids)])
         wids (if reverse? (reverse wids) wids)
         next-wid
         (cond
           ((set wids) active-wid) (let [i (.indexOf wids active-wid)]
                                     (nth wids (inc i)))
           (= (:app_id last-active-window)

              class) (:id last-active-window)
           :else  (first wids)
           )
         ]
     (action :focus-window "--id" next-wid)
     ;; torn, should this be only on global?
     (action :center-window)
     )))


;; ...
(defn find-class-reverse [class]
  (find-class class true))

(defn find-class-current []
  (find-class (-> @niri-state :focused :app_id)))

(defn find-class-all-workspaces [class]
  (find-class class false true))

;; maybe this should be named "big?"
(defn maximized?
  ([] (maximized? (:focused @niri-state)))
  ([window]
   (let [[mon-w mon-h] ((juxt :width :height) (-> @niri-state :output :logical))
         [win-w win-h] (-> window :layout :tile_size)]
     (and
      (> win-w (* 0.8 mon-w))
      (> win-h (* 0.8 mon-h))))))

(defn layout-toggle [slim-toggle]
  (let [fullscreen? (= (-> @niri-state :focused :layout :tile_size)
                       (map double ((juxt :width :height) (:logical (:output @niri-state)))))
        maxed? (maximized?)
        tiled? (and (not maxed?) (not fullscreen?))
        slim? (> 50                     ; percent
                 (/ (-> @niri-state :focused :layout :tile_size first)
                    (:width (:logical (:output @niri-state)))))]

    ;; (second (:workspaces @niri-state))
    ;; (:logical (:output @niri-state))

    ))

(defn switch-preset-width-and-center []
  ;; are we fullscreen? take us out of that
  (if (= (-> @niri-state :focused :layout :tile_size)
         (map double ((juxt :width :height) (:logical (:output @niri-state)))))

    (do
      (action :fullscreen-window)

      (action :set-window-width "50%")
      )
    )

  (action :switch-preset-window-width)

  (Thread/sleep 50)

  ;; todo: diffent action for this

  ;; (when-not (maximized?)
  ;;   (action :focus-column-left)
  ;;   (action :focus-column-right))

  (action :center-window)
  )

(defn maximize-column []
  (if (maximized?)
    (do
      (action :maximize-column)
      ;; (action :maximize-window-to-edges)
      (Thread/sleep 50)

      ;; if the left column will fit, scroll
      (action :focus-column-left)
      (action :focus-column-right)
      ;; (action :center-window)
      )

    ;; (action :maximize-window-to-edges)
    (action :maximize-column)
    ))

(defn force-kill-window []
  (shell/sh "kill" "-9" (-> @niri-state :focused :pid str)))

(defn dismiss []
  (action "move-window-to-workspace-down")
  (action "focus-workspace-up"))

(defn toggle-monocle-mode []
  ;; Toggle between tabbed single column and multiple columns
  (let [windows (-> @niri-state :windows vals)
        current-window (:focused @niri-state)
        term? (= "Alacritty" (:app_id current-window))
        mon-width (-> @niri-state :output :logical :width)
        mon-width (- mon-width 60)      ; gaps
        current-width (* 100 (double (/ (-> current-window :layout :window_size first) mon-width)))
        ;; widthed? (> 3 (abs (- (read-string width) current-width)))
        ;; slim? (> 60 (read-string width))
        workspace-id (:workspace_id current-window)
        workspace-windows (filter #(= workspace-id (:workspace_id %)) windows)]

    (when (> (count workspace-windows) 1)
      (let [column-positions (map #(first (get-in % [:layout :pos_in_scrolling_layout]))
                                  workspace-windows)
            unique-columns (count (distinct column-positions))
            all-tabbed? (= 1 unique-columns)]

        (if all-tabbed?
          ;; Expel all windows from the tabbed column
          (do
            ;; (action :set-column-width "49%") ; sane?
            (action :toggle-column-tabbed-display)
            (action :focus-window-top)
            (dotimes [_ (dec (count workspace-windows))]
              (action :expel-window-from-column)))

          ;; Consume all columns into one tabbed column
          (do
            (action :focus-column-first)
            (action :toggle-column-tabbed-display)
            (dotimes [_ (dec unique-columns)]
              (action :consume-window-into-column))))

        ;; Restore focus to original window
        (action :focus-window "--id" (:id current-window))))))

;; ---------------
(defn niri-state-loop []
  ;; return channel that can be closed, track state here
  (let [proc (process/process ["niri" "msg" "--json" "event-stream"]
                              {:out :stream})
        reader (io/reader (:out proc))
        stop-ch (chan)]
    (go-loop []
      (when-let [line (.readLine reader)]

        (let [[val port] (alts! [stop-ch (timeout 1)])] ; ms, so ~instant
          (if (= port stop-ch)
            (println "niri-state-loop stopping...")
            (do
              (let [event-map (json/parse-string line true)
                    event-type (first (keys event-map))
                    event-data (get event-map event-type)]

                ;; {"WorkspaceUrgencyChanged":{"id":1,"urgent":false}}
                ;; {"WorkspaceActivated":{"id":1,"focused":true}}
                ;; {"WindowFocusChanged":{"id":131}}
                ;; {"WindowUrgencyChanged":{"id":131,"urgent":false}}
                ;; {"WorkspaceActiveWindowChanged":{"workspace_id":1,"active_window_id":175}}
                ;; {"WindowFocusChanged":{"id":175}}
                ;; {"WindowClosed":{"id":131}}

                ;; todo!:
                ;; {"WorkspaceActivated":{"id":9,"focused":true}}
                ;; {"WindowFocusTimestampChanged":{"id":176,"focus_timestamp":{"secs":532737,"nanos":594656257}}}
                ;; {"WorkspaceActiveWindowChanged":{"workspace_id":9,"active_window_id":269}}
                (comment

                  (first
                   (:workspaces
                    @niri-state))

                  )

                (swap! niri-state
                       (fn [s]
                         (case event-type

                           :WindowFocusTimestampChanged (assoc-in s [:windows (:id event-data) :focus_timestamp]
                                                                  (:focus_timestamp event-data))

                           :WorkspaceActiveWindowChanged
                           (assoc-in s [:windows (:id event-data) :focus_timestamp]
                                     (:focus_timestamp event-data))



                           :WorkspacesChanged (assoc s :workspaces (:workspaces event-data))

                           :WindowsChanged (assoc s :windows (into {} (map (juxt :id identity) (:windows event-data))))

                           :WindowClosed (update s :windows #(dissoc % (:id event-data)))
                           :WindowFocusChanged (update s :windows
                                                       #(update-vals % (fn [window]
                                                                         (assoc window :is_focused
                                                                                (= (:id window) (:id event-data))))))

                           ;; idea: here, if it's window opened, we can do window rules
                           :WindowOpenedOrChanged
                           (let [wid (:id (:window event-data))
                                 open? (not (get-in s [:windows wid]))]
                             (when open?
                               #_(let [[w h] (-> s :focused :layout :tile_size)
                                       ;; tile? (> h w)
                                       ;; null exception if h w bad
                                       tile? (<=
                                              (- (max h w) (min h w))
                                              (* 0.90 (min h w)))]
                                   (when tile? ; consume
                                     ;; (action :consume-window-into-column)
                                     ;; (action :consume-or-expel-window-left)
                                     )))

                             (assoc-in s [:windows wid] (:window event-data)))

                           :WindowLayoutsChanged
                           (update s :windows
                                   (fn [old-wins]
                                     (reduce (fn [current [id changes]]
                                               (update-in current [id :layout] #(merge % changes)))
                                             old-wins
                                             (:changes event-data))))

                           ;; ?
                           ;; :WorkspaceActiveWindowChanged
                           ;; (assoc-in s [:workspace-active-windows (:workspace_id event-data)] (:active_window_id event-data))

                           ;; Keep state unchanged for unhandled events
                           ;; log....
                           (do (println "unhandled event: %s" event-type)
                               s))))

                ;; todo: somehow a nil key is ending up in our :windows map
                (swap! niri-state
                       (fn [s]
                         (-> s
                             (assoc :focused-last (:focused s))
                             (assoc :focused (->> (vals (:windows s))
                                                  (filter :is_focused)
                                                  (first))))
                         )))
              (recur))))))
    stop-ch))

;; reset on reload
(do
  (:windows @niri-state)

  (and niri-state-channel (close! niri-state-channel))

  (def niri-state-channel nil)

  (def niri-state (atom {:output (msg :focused-output)}))

  )

(when-not niri-state-channel
  (def niri-state-channel (niri-state-loop)))


(defn- act [line]
  (let [line (string/trim line)
        cmd (string/split line #"\^")]
    (cond
      (= line "quit") nil
      (= line "nop") nil
      (= line "hello") (lib/shh "notify-send hello")
      (= line "ping") "pong"

      ;; todo: error handling
      (-> cmd first symbol resolve) ; defined function
      (try
        (apply println ":" cmd)
        (pr-str
         (apply (-> cmd first symbol resolve)
                (rest cmd)))
        ;; not great at printing..
        (catch Exception e
          (lib/sh "notify-send" (str "nirit failure: " (string/replace line "^" " ")) )
          (prn (ex-data e))
          (println (str e))))

      :else (str "unknown command!: " line))))

(defn main-loop [socket-path-str]
  ;; 1. Use Path/of and convert to a standard String path for the file check
  (let [path-obj (Path/of socket-path-str (into-array String []))
        socket-file (io/file socket-path-str)

        ;; 2. Clear old file lock cleanly
        _ (when (.exists socket-file) (.delete socket-file))

        _ (nrepl/start-server! {:port 6767 :host "localhost"})

        ;; 3. Pass the explicit Path object to UnixDomainSocketAddress/of
        address (UnixDomainSocketAddress/of path-obj)
        server-channel (ServerSocketChannel/open StandardProtocolFamily/UNIX)]

    (.bind server-channel address)
    (println "Server listening on native Unix Socket:" socket-path-str)

    (future
      (while true
        (try
          (let [client-channel (.accept server-channel)
                buffer (ByteBuffer/allocate 1024)
                _ (.read client-channel buffer)

                ;; Convert incoming client stream to string
                request (String. (.array buffer) 0 (.position buffer))

                ;; todo: quit
                response (str (or (act request) "") "\n")
                ]

            ;; Write back to client instantly
            (.write client-channel (ByteBuffer/wrap (.getBytes response)))

            ;; Explicitly close client connection to send EOF immediately
            (.close client-channel))
          (catch Exception e
            (println "Socket connection error:" (.getMessage e))))))))


#_(defn main-loop []
    (when (fs/exists? SOCKET)
      (fs/delete SOCKET))


    (let [proc (process/process ["socat" "-u" "-b" "1" (format "UNIX-LISTEN:%s,fork,reuseaddr" SOCKET) "-"])]
      (with-open [rdr (io/reader (:out proc))
                  wtr (io/writer (:in proc))]
        (loop [line "nop"]


          (when-not (= line "nop")
            (.write wtr "\n"))

          (.flush wtr)
          ;; (.close wtr)

          (if (= line "quit")
            (and (process/destroy proc) true)
            (recur (first (line-seq rdr))))))))

(defn kdl->edn [kdl]
  (->> kdl
       (clojure.string/split-lines)
       (map clojure.string/trim)
       (remove #(clojure.string/starts-with? % "//"))
       (remove clojure.string/blank?)
       (map (fn [s]
              (if (#{\{ \}} (first s))
                s
                (str ":" s))))
       (clojure.string/join " ")
       (format "{%s}")
       (read-string)))

;; slop
(defn map->kdl [data]
  (letfn [(emit-val [v]
            ;; (prn "what " v)
            (cond
              (string? v) (if (parse-long v)
                            (str " " (parse-long v))
                            (str " " (pr-str v)))
              (keyword? v) (name v)
              (map? v) (str " {\n" (apply str (map (fn [[k v2]] (str "  " (name k) (emit-val v2) "\n")) v)) "}")
              :else (str " " v)))
          (emit [m]
            (apply str (map (fn [[k v]] (str (name k) (emit-val v) "\n")) m)))]
    (emit data)))

(defn kdl-assoc-in [file ks v]
  (let [m (kdl->edn (slurp file))]
    (spit file (map->kdl (assoc-in m ks v)))))

(defn kdl-update-in [file ks f]
  (let [m (kdl->edn (slurp file))]
    (spit file (map->kdl (update-in m ks f)))))

(defn config
  ([path] (let [m (kdl->edn (slurp (lib/home ".config/niri/gaps.kdl")))]
            (get-in m (map keyword (string/split path #"-")) "not-found")))
  ([path v]
   (kdl-assoc-in (lib/home ".config/niri/gaps.kdl")
                 ;; layout-struts-top -> [:layout :struts :top]
                 (map keyword (string/split path #"-"))
                 v)))

