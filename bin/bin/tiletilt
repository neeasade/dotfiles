#!/usr/bin/env bash
# view a tiled wallpaper at an angles

tiledir="${HOME}/tiles"

tile=${1:-$(find "$tiledir/" -type f | shuf | head -n 1)}

angle=$2

if [ -z "$angle" ]; then
    # angle=$(elisp '(ns/random-list (range 0 360 15))')
    angle=$((RANDOM % 360))
fi

w=1920
h=1080

type xdpyinfo >/dev/null 2>&1 && \
    read -r w h <<< "$(xdpyinfo | awk -F'[ x]+' '/dimensions/{print $3 " " $4}')"

if [[ -p /dev/stdout ]]; then
    out=cat
else
    out="feh --bg-tile -"
    out="awww img -t none -"
fi

magick "$tile" -set option:distort:viewport "${w}x${h}" \
    -virtual-pixel tile -filter point \
    -distort SRT "$angle" \
    -gravity center -crop "${w}x${h}+0+0" +repage \
    "PNG:-" | $out
    # /tmp/background.png

printf "tiletilt '%s' %s\n" "$tile" "$angle"
# awww img -t none /tmp/background.png
